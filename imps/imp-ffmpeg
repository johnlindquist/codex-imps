gif from video (two-pass palette) -> ffmpeg -n -i INPUT.mp4 -vf "fps=12,scale=480:-1:flags=lanczos,palettegen" palette.png then ffmpeg -n -i INPUT.mp4 -i palette.png -filter_complex "fps=12,scale=480:-1:flags=lanczos[x];[x][1:v]paletteuse" OUTPUT_anim.gif
